JWT_SECRET_KEY=replace-with-a-long-random-secret
USE_REAL_AWS=true
REPORT_BUCKET=xxxxxxxxxxx-iam-scanner-reports
AWS_DEFAULT_REGION=ap-southeast-2

# Fix #2 — controls whether /docs, /redoc, /openapi.json are served,
# AND whether the auth cookie gets the Secure flag (HTTPS-only).
# Use "development" locally, "production" on any real deployment.
ENVIRONMENT=development

# Fix #4 — JWT lifetime in minutes. Reduced default from 480 to 60.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Fix H-3 — set to "true" to REFUSE serving any S3 report object that
# isn't encrypted at rest (fail-closed). Default (unset/false) logs a
# warning but still serves the report, preserving dashboard behaviour.
S3_REQUIRE_ENCRYPTION=false

# Fix H-2 (reminder) — these webhook URLs MUST be https:// or the senders
# will refuse to post. They are secrets; set via environment only.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# TEAMS_WEBHOOK_URL=https://prod-XX.westus.logic.azure.com/workflows/...