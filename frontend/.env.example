# L-2 WARNING — every VITE_-prefixed variable is baked into the compiled
# JavaScript bundle at build time and is readable by anyone who loads the
# app in a browser. NEVER put secrets (API keys, webhook URLs, anything
# AWS) behind a VITE_ prefix — secrets belong in backend/.env only.

# Base URL of the FastAPI backend. Leave empty to use the Vite dev proxy
# (recommended for local dev). Set to the deployed API origin in builds.
VITE_API_BASE_URL=
